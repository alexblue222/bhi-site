---
interface Props { eyebrow: string; title: string; sub?: string; wip?: boolean; }
const { eyebrow, title, sub, wip = true } = Astro.props;
---
<section class="relative flex min-h-[68vh] items-center justify-center overflow-hidden px-6 pt-32 pb-20">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(46,155,255,0.5), transparent)"></div>
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#58d6ff]">{eyebrow}</p>
    <h1 class="mt-4 text-4xl font-semibold text-slate-100 sm:text-5xl">{title}</h1>
    {sub && <p class="mx-auto mt-5 max-w-xl leading-relaxed text-slate-400">{sub}</p>}
    {wip && (
      <p class="mt-9 inline-block rounded-full border border-white/10 bg-white/[0.02] px-4 py-1.5 text-[11px] uppercase tracking-[0.22em] text-slate-500">
        In progress
      </p>
    )}
  </div>
</section>
