---
import Layout from "../layouts/Layout.astro";
import { LoadingScreen } from "../components/site/LoadingScreen.tsx";
import HeroStage from "../components/hero/HeroStage.tsx";
import Spine from "../components/hero/Spine.tsx";
import HomeScenes from "../components/home/HomeScenes.tsx";
// HubSections (the rich content homepage) is kept in the codebase for later — Stage 3
// swaps in the scene scaffold to nail scroll + spacing first, with placeholder planets.
---

<Layout hero>
  <LoadingScreen client:load />
  <HeroStage client:only="react" />
  <Spine client:only="react" />
  {/* transparent so the fixed master planet layer (z-5, portaled by HomeScenes)
      shows through behind the scene text; body carries the dark bg */}
  <main class="relative z-10">
    <HomeScenes client:load />
  </main>
</Layout>
