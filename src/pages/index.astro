---
import Layout from "../layouts/Layout.astro";
import HeroStage from "../components/hero/HeroStage.tsx";
import HubSections from "../components/home/HubSections";
import { getArtists, getStaticFeed } from "../lib/content";

// Server → island props: git-content feed (pins + blog) and the roster.
// The island does no client fetching — data is baked in at build time.
const feed = (await getStaticFeed()).slice(0, 3);
const artists = await getArtists();
---

<Layout hero>
  <HeroStage client:only="react" />
  <main class="relative z-10 bg-[#01030a]">
    <HubSections client:visible feed={feed} artists={artists} />
  </main>
</Layout>
