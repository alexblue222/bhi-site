---
import Layout from "../layouts/Layout.astro";
import PageIntro from "../components/site/PageIntro.astro";
import { MediaTile } from "../components/ui/MediaTile";
import { Connect } from "../components/ui/Connect";
import { GAMES } from "../components/home/HubSections";
---

<Layout
  title="Studio — Blue Horizon Interactive"
  description="The games and real-time worlds in production at Blue Horizon Interactive."
>
  <PageIntro
    eyebrow="The Studio"
    title="Worlds in production"
    sub="The games and real-time worlds we're building — designed to feel like a glimpse of what's next. Follow every one as it comes together, devlog by devlog."
    wip={false}
  />

  <section class="border-t border-white/5 px-6 py-24">
    <div class="mx-auto max-w-6xl space-y-24">
      {GAMES.map((g, i) => (
        <article class="grid items-center gap-10 md:grid-cols-2">
          {/* art — alternates side on desktop; set g.cover to a screenshot to replace the gradient */}
          <div class={i % 2 === 1 ? "md:order-2" : ""}>
            <MediaTile tint={g.tint} aspect="video" label={!g.cover ? g.title : undefined} className="w-full ring-1 ring-white/10">
              {g.cover && (
                <img src={g.cover} alt={`${g.title} — screenshot`} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
              )}
            </MediaTile>
          </div>
          <div class={i % 2 === 1 ? "md:order-1" : ""}>
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-bh-cyan/80">{g.status}</p>
            <h2 class="mt-2 font-display text-3xl font-semibold text-slate-100 sm:text-4xl">{g.title}</h2>
            <p class="mt-4 leading-relaxed text-slate-400">{g.longPitch ?? g.pitch}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {g.tags.map((t) => (
                <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-400">{t}</span>
              ))}
            </div>
            <a
              href="/feed"
              class="mt-7 inline-flex items-center gap-2 rounded-full border border-bh-blue/40 bg-bh-blue/10 px-6 py-3 text-sm font-medium text-[#bfe0ff] transition-colors hover:bg-bh-blue/20"
            >
              Follow development in the feed <span aria-hidden>→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Closer -->
  <section class="border-t border-white/5 px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-bh-cyan">More on the horizon</p>
      <p class="mx-auto mt-4 max-w-lg leading-relaxed text-slate-400">
        This is the world in the open. More are in the dark, not yet lit — every build ships its
        devlogs to the feed as it comes together.
      </p>
      <div class="mt-10 flex justify-center">
        <Connect compact />
      </div>
    </div>
  </section>
</Layout>
