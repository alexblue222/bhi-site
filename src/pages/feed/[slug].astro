---
import Layout from "../../layouts/Layout.astro";
import { PlatformBadge } from "../../components/ui/PlatformBadge";
import { MediaTile } from "../../components/ui/MediaTile";
import { SectionHead } from "../../components/ui/SectionHead";
import { Connect } from "../../components/ui/Connect";
import { FeedCard } from "../../components/cards/FeedCard";
import { FEED, firstPartyPosts, getArtist, relTime, type FeedItem } from "../../lib/data";

export function getStaticPaths() {
  return firstPartyPosts().map((item) => ({ params: { slug: item.slug! }, props: { item } }));
}

interface Props {
  item: FeedItem;
}
const { item } = Astro.props;
const artist = getArtist(item.author);
const more = FEED.filter((f) => f.id !== item.id)
  .sort((a, b) => b.publishedAt.localeCompare(a.publishedAt))
  .slice(0, 3);
---

<Layout title={`${item.title} — Blue Horizon Interactive`} description={item.excerpt}>
  <article class="mx-auto max-w-3xl px-6 pt-32 pb-24">
    <a href="/feed" class="text-sm text-slate-500 transition-colors hover:text-bh-cyan">← All updates</a>

    <div class="mt-8 flex flex-wrap items-center gap-2.5">
      <PlatformBadge platform={item.platform} />
      <span class="text-xs text-slate-500">{relTime(item.publishedAt)}</span>
      {item.tags?.map((t) => (
        <span class="rounded-full border border-white/10 px-2.5 py-0.5 text-xs text-slate-400">{t}</span>
      ))}
    </div>

    <h1 class="mt-5 text-4xl font-semibold text-slate-100">{item.title}</h1>

    {item.media && <MediaTile tint={item.media.tint} label={item.media.label} aspect="wide" className="mt-8" />}

    <div class="mt-8 space-y-5 leading-relaxed text-slate-300">
      {item.body?.map((p) => <p>{p}</p>)}
    </div>

    {artist && (
      <a
        href={`/artists/${artist.slug}`}
        class="mt-12 inline-flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.02] px-5 py-4 transition-colors hover:border-bh-blue/40"
      >
        <span
          class={`flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br ${artist.avatarTint} text-xs font-semibold text-white`}
        >
          {artist.initials}
        </span>
        <span>
          <span class="block text-sm font-medium text-slate-200">{artist.name}</span>
          <span class="block text-xs text-slate-500">{artist.role}</span>
        </span>
      </a>
    )}
  </article>

  <section class="border-t border-white/5 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <SectionHead eyebrow="Keep scrolling" title="More from the feed" align="left" />
      <div class="mt-10 grid gap-5 sm:grid-cols-3">
        {more.map((f) => <FeedCard item={f} />)}
      </div>
      <div class="mt-16">
        <Connect />
      </div>
    </div>
  </section>
</Layout>
