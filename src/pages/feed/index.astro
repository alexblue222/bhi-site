---
import Layout from "../../layouts/Layout.astro";
import { FeedStream } from "../../components/feed/FeedStream";
import { getStaticFeed } from "../../lib/content";

// Git content (pins + blog) is baked in at build time and server-rendered
// immediately; the island merges live Worker items on top in the browser.
const items = await getStaticFeed();
---

<Layout
  title="The Feed — Blue Horizon Interactive"
  description="Every video, devlog, release and post from Blue Horizon Interactive — YouTube, Patreon, Instagram, TikTok, the marketplaces and the studio — in one stream."
>
  <!-- Oversized editorial intro — left-aligned on the column axis, horizon hairlines -->
  <section class="relative overflow-hidden px-6 pb-4 pt-36 sm:pt-44">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px"
      style="background: linear-gradient(90deg, transparent, rgba(46,155,255,0.5), transparent)"
    >
    </div>
    <div
      class="pointer-events-none absolute left-1/2 top-[-14rem] h-[26rem] w-[40rem] -translate-x-1/2 rounded-full bg-bh-blue/10 blur-[120px]"
    >
    </div>
    <div class="mx-auto max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-bh-cyan">The signal</p>
      <h1 class="mt-5 text-5xl font-semibold tracking-tight text-slate-100 sm:text-6xl md:text-7xl">
        Everything,<br class="hidden sm:block" /> in one feed
      </h1>
      <p class="mt-7 max-w-xl leading-relaxed text-slate-400">
        Every video, devlog, release and post — from YouTube, Patreon, Instagram, TikTok, the
        marketplaces and the studio itself — lands here, in one stream.
      </p>
      <div class="mt-14 h-px w-full bg-gradient-to-r from-white/15 via-white/5 to-transparent"></div>
    </div>
  </section>

  <section class="px-6 pb-28 pt-10">
    <div class="mx-auto max-w-3xl">
      <FeedStream initial={items} client:load />
    </div>
  </section>
</Layout>
