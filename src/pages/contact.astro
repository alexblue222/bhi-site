---
import Layout from "../layouts/Layout.astro";
import PageIntro from "../components/site/PageIntro.astro";
import { ContactForm } from "../components/site/ContactForm";
---
<Layout title="Contact — Blue Horizon Interactive" description="Get in touch with Blue Horizon Interactive.">
  <PageIntro
    eyebrow="Contact"
    title="Get in touch"
    sub="Working on something, or want to work together? Tell us what you're building."
    wip={false}
  />
  <section class="px-6 pb-28">
    <div class="mx-auto max-w-xl">
      <ContactForm client:load />
      <p class="mt-6 text-center text-sm text-slate-500">
        Prefer email? <a href="mailto:hello@bluehorizoninteractive.com" class="text-bh-cyan hover:underline">hello@bluehorizoninteractive.com</a>
      </p>
    </div>
  </section>
</Layout>
