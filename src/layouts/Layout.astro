---
import "../styles/global.css";
import { Header } from "../components/site/Header";
import { Footer } from "../components/site/Footer";

interface Props {
  title?: string;
  description?: string;
  /** True on pages with the scroll hero — the header logo waits for the dock hand-off. */
  hero?: boolean;
}
const {
  title = "Blue Horizon Interactive — Games of the Future",
  description = "Blue Horizon Interactive is an Irish studio building the games of the future — and the technology that renders them.",
  hero = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#01030a" />
    <meta property="og:title" content="Blue Horizon Interactive" />
    <meta property="og:description" content="An Irish studio building the games of the future." />
    <meta property="og:type" content="website" />
    <!-- Michroma = the logo face (brand moments only) · Space Grotesk = display · Inter = body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Michroma&family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <!-- WIP: keep out of search until content is real -->
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-[#01030a] text-slate-200">
    <Header hero={hero} client:load />
    <slot />
    <Footer />
  </body>
</html>
